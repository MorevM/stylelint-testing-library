{
	"name": "@morev/stylelint-testing-library",
	"description": "Platform agnostic solution for testing Stylelint plugins",
	"type": "module",
	"version": "1.1.0",
	"engines": {
		"node": ">=18"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"author": {
		"name": "Maxim Morev",
		"email": "max.seainside@gmail.com"
	},
	"homepage": "https://github.com/MorevM/stylelint-testing-library#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/MorevM/stylelint-testing-library"
	},
	"keywords": [
		"stylelint",
		"stylelint-plugin",
		"testing",
		"testing-library"
	],
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"prepare": "lefthook install",
		"test": "vitest",
		"typecheck": "tsc --noEmit",
		"test:dev": "vitest --watch",
		"lint": "pnpm lint:eslint && pnpm lint:stylelint",
		"lint:fix": "pnpm lint:eslint:fix && pnpm lint:stylelint:fix",
		"lint:eslint": "eslint .",
		"lint:eslint:fix": "eslint . --fix",
		"lint:stylelint": "stylelint \"**/*.css}\" --allow-empty-input",
		"lint:stylelint:fix": "stylelint \"**/*.css\" --fix --allow-empty-input",
		"build": "tsdown",
		"release": "release-it --disable-metrics",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs"
	},
	"peerDependencies": {
		"stylelint": ">=16"
	},
	"dependencies": {
		"@morev/utils": "^3.15.0"
	},
	"devDependencies": {
		"@morev/commitlint-config": "^0.2.2",
		"@morev/eslint-config": "^41.0.0",
		"@morev/stylelint-config": "^8.0.2",
		"@release-it/conventional-changelog": "8.0.2",
		"@shikijs/transformers": "^4.0.2",
		"@types/node": "^22.13.4",
		"eslint": "9.39.4",
		"lefthook": "^2.1.6",
		"postcss": "^8.5.14",
		"release-it": "^20.0.1",
		"stylelint": "^17.11.0",
		"tsdown": "^0.22.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.11",
		"vitepress": "^1.6.3",
		"vitest": "^4.1.6",
		"vue": "^3.5.34"
	}
}
